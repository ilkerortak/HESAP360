<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="referrer" content="no-referrer">
    <title>Kredi Karşılaştır | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #020617; --surface: #0f172a; --primary: #3b82f6; --border: rgba(255, 255, 255, 0.08); }
        body { background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; margin: 0; }
        .container { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }
        .back-btn { color: var(--primary); text-decoration: none; font-weight: 700; margin-bottom: 20px; display: inline-block; }
        .filter-card { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 25px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
        input[type="range"] { width: 100%; accent-color: var(--primary); }
        .bank-row { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 20px; display: grid; grid-template-columns: 140px 1fr 1fr 1fr 140px; align-items: center; gap: 15px; margin-bottom: 12px; }
        .bank-logo { background: #fff; padding: 5px; border-radius: 8px; height: 45px; display: flex; align-items: center; justify-content: center; }
        .bank-logo img { max-width: 100%; max-height: 100%; object-fit: contain; }
        .btn-apply { background: var(--primary); color: #fff; text-decoration: none; padding: 10px; border-radius: 10px; text-align: center; font-weight: 700; font-size: 0.9rem; }
    </style>
</head>
<body>
<div class="container">
    <a href="/" class="back-btn">← Geri Dön</a>
    <div class="filter-card">
        <div><label>TUTAR: <b id="aTxt" style="color:var(--primary)">100.000 ₺</b></label><input type="range" id="amount" min="10000" max="1000000" step="10000" value="100000" oninput="calc()"></div>
        <div><label>VADE: <b id="tTxt" style="color:var(--primary)">12 AY</b></label><input type="range" id="term" min="3" max="36" step="1" value="12" oninput="calc()"></div>
    </div>
    <div id="results">
        <% banks.forEach(bank => { %>
        <div class="bank-row" data-rate="<%= bank.krediOran %>">
            <div class="bank-logo"><img src="<%= bank.logo %>" alt="<%= bank.ad %>"></div>
            <div><small>FAİZ</small><br><b style="color:#10b981;">%<%= bank.krediOran %></b></div>
            <div><small>TAKSİT</small><br><b class="inst">0 ₺</b></div>
            <div><small>TOPLAM</small><br><b class="total">0 ₺</b></div>
            <a href="#" class="btn-apply">BAŞVUR</a>
        </div>
        <% }) %>
    </div>
</div>
<script>
    function calc() {
        const amount = parseFloat(document.getElementById('amount').value) || 100000;
        const term = parseInt(document.getElementById('term').value) || 12;
        document.getElementById('aTxt').innerText = amount.toLocaleString('tr-TR') + " ₺";
        document.getElementById('tTxt').innerText = term + " AY";
        document.querySelectorAll('.bank-row').forEach(row => {
            const rate = parseFloat(row.getAttribute('data-rate'));
            if (!isNaN(rate)) {
                const monthlyRate = rate / 100;
                const installment = (amount * monthlyRate * Math.pow(1 + monthlyRate, term)) / (Math.pow(1 + monthlyRate, term) - 1);
                row.querySelector('.inst').innerText = Math.floor(installment).toLocaleString('tr-TR') + " ₺";
                row.querySelector('.total').innerText = Math.floor(installment * term).toLocaleString('tr-TR') + " ₺";
            }
        });
    }
    window.onload = calc;
</script>
</body>
</html>
