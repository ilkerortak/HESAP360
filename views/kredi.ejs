<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Kredi Karşılaştır | Hesap360</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    </head>
<body>
    <div class="container" style="max-width: 1000px; margin: 40px auto; padding: 0 20px;">
        <a href="/" class="back-link"><i class="fa-solid fa-chevron-left"></i> Ana Sayfaya Dön</a>
        
        <h1 style="font-size: 3rem; font-weight: 800; letter-spacing: -2px; margin-bottom: 40px;">Kredi Teklifleri</h1>

        <div class="calc-card" style="background: var(--surface); padding: 40px; border-radius: 30px; margin-bottom: 40px; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; border: 1px solid var(--border);">
            <div>
                <label style="display:block; font-weight:700; color:var(--blue); margin-bottom:10px;">Tutar: <span id="aT">100.000 TL</span></label>
                <input type="range" id="amount" min="10000" max="1000000" step="10000" value="100000" style="width:100%; accent-color:var(--blue);" oninput="run()">
            </div>
            <div>
                <label style="display:block; font-weight:700; color:var(--blue); margin-bottom:10px;">Vade: <span id="tT">12 Ay</span></label>
                <input type="range" id="term" min="3" max="36" value="12" style="width:100%; accent-color:var(--blue);" oninput="run()">
            </div>
        </div>

        <div id="results">
            <% banks.forEach(bank => { %>
                <div class="bank-row" data-rate="<%= bank.kredi %>" style="background: var(--bg); border: 1px solid var(--border); border-radius: 24px; padding: 30px; margin-bottom: 15px; display: flex; align-items: center; justify-content: space-between; transition: 0.2s;">
                    <img src="<%= bank.logo %>" style="height: 40px; width: 120px; object-fit: contain; filter: grayscale(0.2);">
                    <div style="text-align:center;"><small style="opacity:0.6;">FAİZ</small><br><b style="font-size:1.2rem;">%<%= bank.kredi %></b></div>
                    <div style="text-align:center;"><small style="opacity:0.6;">TAKSİT</small><br><b class="iVal" style="font-size:1.2rem;">0 TL</b></div>
                    <a href="#" style="background: var(--blue); color: white; text-decoration: none; padding: 12px 30px; border-radius: 50px; font-weight: 700;">Başvur</a>
                </div>
            <% }) %>
        </div>
    </div>
    <script>
        function run() {
            const a = parseFloat(document.getElementById('amount').value);
            const t = parseInt(document.getElementById('term').value);
            document.getElementById('aT').innerText = a.toLocaleString('tr-TR') + " TL";
            document.getElementById('tT').innerText = t + " Ay";
            document.querySelectorAll('.bank-row').forEach(c => {
                const r = parseFloat(c.getAttribute('data-rate')) / 100;
                const inst = (a * r * Math.pow(1 + r, t)) / (Math.pow(1 + r, t) - 1);
                c.querySelector('.iVal').innerText = Math.floor(inst).toLocaleString('tr-TR') + " TL";
            });
        }
        window.onload = run;
    </script>
</body>
</html>
