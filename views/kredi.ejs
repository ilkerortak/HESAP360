<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kredi Karşılaştırma | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root { --bg: #020617; --surface: #0f172a; --primary: #3b82f6; --border: rgba(255, 255, 255, 0.08); --text-dim: #94a3b8; }
        body { background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; margin: 0; background-image: radial-gradient(circle at 50% -20%, #1e40af33 0%, transparent 50%); }
        .container { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }
        nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
        .logo { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; }
        .logo span { color: var(--primary); }
        .calc-card { background: var(--surface); border: 1px solid var(--border); border-radius: 24px; padding: 40px; margin-bottom: 30px; }
        .input-group { margin-bottom: 25px; }
        label { display: flex; justify-content: space-between; margin-bottom: 12px; color: var(--text-dim); font-weight: 700; font-size: 0.8rem; }
        input[type="range"] { width: 100%; height: 6px; background: #1e293b; border-radius: 5px; appearance: none; outline: none; }
        input[type="range"]::-webkit-slider-thumb { appearance: none; width: 24px; height: 24px; background: var(--primary); border-radius: 50%; cursor: pointer; border: 4px solid #fff; }
        .bank-card { background: var(--surface); border: 1px solid var(--border); padding: 25px; border-radius: 20px; display: grid; grid-template-columns: 1fr 1fr 1fr 150px; align-items: center; gap: 20px; margin-bottom: 15px; }
        .bank-name { font-weight: 800; font-size: 1.2rem; }
        .stat-val { display: block; font-size: 1.1rem; font-weight: 700; color: var(--primary); }
        .stat-label { font-size: 0.7rem; color: var(--text-dim); }
        .btn-apply { background: var(--primary); color: #fff; border: none; padding: 12px; border-radius: 12px; font-weight: 700; cursor: pointer; text-decoration: none; text-align: center; }
    </style>
</head>
<body>
    <div class="container">
        <nav><a href="/" class="logo">HESAP<span>360</span></a><a href="/" style="color:var(--text-dim); text-decoration:none;"><i class="fa-solid fa-arrow-left"></i> Geri</a></nav>
        <div class="calc-card">
            <div class="input-group"><label>TUTAR: <span id="amountTxt">100.000 ₺</span></label><input type="range" id="amount" min="5000" max="1000000" step="5000" value="100000" oninput="calc()"></div>
            <div class="input-group"><label>VADE: <span id="termTxt">12 Ay</span></label><input type="range" id="term" min="3" max="36" step="1" value="12" oninput="calc()"></div>
        </div>
        <div id="results"></div>
    </div>
    <script>
        const banks = [{n:'A Bank', r:3.89}, {n:'B Bank', r:4.15}, {n:'C Bank', r:3.75}];
        function calc() {
            const a = document.getElementById('amount').value; const t = document.getElementById('term').value;
            document.getElementById('amountTxt').innerText = parseInt(a).toLocaleString() + " ₺";
            document.getElementById('termTxt').innerText = t + " Ay";
            const res = document.getElementById('results'); res.innerHTML = '';
            banks.forEach(b => {
                const ir = b.r / 100;
                const inst = (a * ir * Math.pow(1+ir, t)) / (Math.pow(1+ir, t) - 1);
                res.innerHTML += `<div class="bank-card"><div><span class="bank-name">${b.n}</span><span class="stat-label">Faiz: %${b.r}</span></div><div><span class="stat-label">AYLIK TAKSİT</span><span class="stat-val">${Math.floor(inst).toLocaleString()} ₺</span></div><div><span class="stat-label">TOPLAM</span><span class="stat-val">${Math.floor(inst*t).toLocaleString()} ₺</span></div><button class="btn-apply">BAŞVUR</button></div>`;
            });
        }
        window.onload = calc;
    </script>
</body>
</html>
