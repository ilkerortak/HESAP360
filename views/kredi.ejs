<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kredi Karşılaştır | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --bg: #020617;
            --surface: #0f172a;
            --primary: #3b82f6;
            --border: rgba(255, 255, 255, 0.08);
            --text-dim: #94a3b8;
            --success: #10b981;
        }

        body { 
            background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; margin: 0;
            background-image: radial-gradient(circle at 50% -20%, #1e40af44 0%, transparent 60%);
            min-height: 100vh;
        }

        .container { max-width: 1100px; margin: 0 auto; padding: 40px 20px; }

        nav { margin-bottom: 40px; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; }
        .logo span { color: var(--primary); }

        /* Filtreleme Paneli */
        .filter-bar {
            background: var(--surface); border: 1px solid var(--border);
            padding: 30px; border-radius: 24px; display: grid;
            grid-template-columns: 1fr 1fr 180px; gap: 20px;
            margin-bottom: 40px; align-items: end;
        }

        .input-group { display: flex; flex-direction: column; gap: 8px; }
        label { color: var(--text-dim); font-size: 0.75rem; font-weight: 700; letter-spacing: 1px; }
        input {
            background: #020617; border: 1px solid var(--border); padding: 14px; 
            border-radius: 12px; color: #fff; font-size: 1rem; outline: none;
        }
        .btn-update {
            background: var(--primary); color: #fff; border: none; padding: 14px;
            border-radius: 12px; font-weight: 800; cursor: pointer; transition: 0.3s;
        }
        .btn-update:hover { background: #2563eb; }

        /* Banka Listesi */
        .loan-list { display: flex; flex-direction: column; gap: 15px; }
        .loan-card {
            background: var(--surface); border: 1px solid var(--border);
            padding: 25px; border-radius: 20px; display: grid;
            grid-template-columns: 180px 1fr 1fr 1fr 180px;
            align-items: center; gap: 20px; transition: 0.3s;
        }
        .loan-card:hover { border-color: var(--primary); transform: scale(1.01); }

        .bank-info img { width: 120px; filter: grayscale(1) brightness(2); }
        .bank-name { display: block; font-size: 0.8rem; color: var(--text-dim); margin-top: 5px; }

        .stat-label { font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; display: block; }
        .stat-val { font-size: 1.1rem; font-weight: 700; }

        .btn-apply {
            background: rgba(59, 130, 246, 0.1); color: var(--primary); border: 1px solid var(--primary);
            padding: 12px; border-radius: 10px; font-weight: 700; text-decoration: none;
            text-align: center; font-size: 0.9rem; transition: 0.3s;
        }
        .btn-apply:hover { background: var(--primary); color: #fff; }

        @media (max-width: 900px) {
            .loan-card { grid-template-columns: 1fr 1fr; text-align: center; }
            .filter-bar { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<div class="container">
    <nav>
        <a href="/" class="logo">HESAP<span>360</span></a>
        <a href="/" style="color: var(--text-dim); text-decoration: none; font-size: 0.9rem;"><i class="fa-solid fa-house"></i> Ana Sayfa</a>
    </nav>

    <div class="filter-bar">
        <div class="input-group">
            <label>KREDİ TUTARI (₺)</label>
            <input type="number" id="amount" value="100000">
        </div>
        <div class="input-group">
            <label>VADE (AY)</label>
            <input type="number" id="term" value="12">
        </div>
        <button class="btn-update" onclick="calculateLoans()">ORANLARI GÜNCELLE</button>
    </div>

    <div class="loan-list" id="loanContainer">
        </div>
</div>

<script>
    const banks = [
        { name: 'X Bank', rate: 3.89, logo: 'https://via.placeholder.com/120x40/0f172a/3b82f6?text=BANK+A' },
        { name: 'Y Bank', rate: 4.15, logo: 'https://via.placeholder.com/120x40/0f172a/3b82f6?text=BANK+B' },
        { name: 'Z Bank', rate: 3.75, logo: 'https://via.placeholder.com/120x40/0f172a/3b82f6?text=BANK+C' }
    ];

    function calculateLoans() {
        const amount = parseFloat(document.getElementById('amount').value);
        const term = parseInt(document.getElementById('term').value);
        const container = document.getElementById('loanContainer');
        container.innerHTML = '';

        banks.sort((a, b) => a.rate - b.rate).forEach(bank => {
            const monthlyRate = bank.rate / 100;
            const installment = (amount * monthlyRate * Math.pow(1 + monthlyRate, term)) / (Math.pow(1 + monthlyRate, term) - 1);
            const totalPayable = installment * term;

            container.innerHTML += `
                <div class="loan-card">
                    <div class="bank-info">
                        <img src="${bank.logo}" alt="${bank.name}">
                        <span class="bank-name">${bank.name}</span>
                    </div>
                    <div>
                        <span class="stat-label">FAİZ ORANI</span>
                        <span class="stat-val" style="color: var(--success);">%${bank.rate}</span>
                    </div>
                    <div>
                        <span class="stat-label">AYLIK TAKSİT</span>
                        <span class="stat-val">${Math.floor(installment).toLocaleString('tr-TR')} ₺</span>
                    </div>
                    <div>
                        <span class="stat-label">TOPLAM GERİ ÖDEME</span>
                        <span class="stat-val">${Math.floor(totalPayable).toLocaleString('tr-TR')} ₺</span>
                    </div>
                    <a href="#" class="btn-apply">BAŞVUR <i class="fa-solid fa-chevron-right"></i></a>
                </div>
            `;
        });
    }

    // İlk açılışta çalıştır
    window.onload = calculateLoans;
</script>

</body>
</html>
