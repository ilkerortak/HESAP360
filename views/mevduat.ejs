<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Mevduat Getirisi | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --blue: #0066ff; --bg: #f8fafc; --green: #10b981; }
        body { background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: #1a1a1a; margin: 0; }
        .container { max-width: 900px; margin: 50px auto; padding: 0 20px; }
        .filter-box { background: #fff; padding: 35px; border-radius: 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 30px; border: 1px solid #edf2f7; margin-bottom: 30px; }
        .f-item b { font-size: 1.4rem; color: var(--blue); }
        input[type="range"] { width: 100%; accent-color: var(--blue); }
        .bank-item { background: #fff; padding: 25px; border-radius: 20px; display: flex; align-items: center; justify-content: space-between; border: 1px solid #edf2f7; margin-bottom: 15px; }
        .logo-box img { height: 45px; width: 110px; object-fit: contain; }
        .val-item b { font-size: 1.15rem; }
        .gain { color: var(--green) !important; }
        .apply-btn { border: 2px solid var(--blue); color: var(--blue); text-decoration: none; padding: 10px 25px; border-radius: 12px; font-weight: 700; }
    </style>
</head>
<body>
    <div class="container">
        <h2 style="font-weight: 800; margin-bottom: 30px;">Mevduat Kazanç Analizi</h2>
        <div class="filter-box">
            <div class="f-item"><label>ANAPARA</label><br><b id="aT">50.000 TL</b><input type="range" id="capital" min="1000" max="2000000" step="5000" value="50000" oninput="calc()"></div>
            <div class="f-item"><label>VADE (GÜN)</label><br><b id="dT">32 GÜN</b><input type="range" id="days" min="1" max="365" step="1" value="32" oninput="calc()"></div>
        </div>
        <div id="bankList">
            <% banks.forEach(bank => { %>
                <div class="bank-item" data-rate="<%= bank.mevduat %>">
                    <div class="logo-box"><img src="<%= bank.logo %>"></div>
                    <div class="val-item"><small style="color:#94a3b8">FAİZ</small><br><b>%<%= bank.mevduat %></b></div>
                    <div class="val-item"><small style="color:#94a3b8">NET GETİRİ</small><br><b class="gain gVal">0 TL</b></div>
                    <div class="val-item"><small style="color:#94a3b8">TOPLAM</small><br><b class="tVal">0 TL</b></div>
                    <a href="#" class="apply-btn">Hesap Aç</a>
                </div>
            <% }) %>
        </div>
    </div>
    <script>
        function calc() {
            const c = parseFloat(document.getElementById('capital').value);
            const d = parseInt(document.getElementById('days').value);
            document.getElementById('aT').innerText = c.toLocaleString('tr-TR') + " TL";
            document.getElementById('dT').innerText = d + " GÜN";
            document.querySelectorAll('.bank-item').forEach(card => {
                const r = parseFloat(card.getAttribute('data-rate'));
                const netGain = (c / 100) * (r / 365) * d * 0.95; // %5 stopaj düşüldü
                card.querySelector('.gVal').innerText = Math.floor(netGain).toLocaleString('tr-TR') + " TL";
                card.querySelector('.tVal').innerText = Math.floor(c + netGain).toLocaleString('tr-TR') + " TL";
            });
        }
        window.onload = calc;
    </script>
</body>
</html>
