<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mevduat Getirisi | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        /* TAM RENK KONTROLÜ */
        :root { 
            --bg: #020617; 
            --surface: #0f172a; 
            --primary: #3b82f6; /* KESİN MAVİ */
            --primary-glow: rgba(59, 130, 246, 0.2);
            --border: rgba(255, 255, 255, 0.08); 
            --text-dim: #94a3b8; 
        }

        body { 
            background: var(--bg); 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            color: #fff; 
            margin: 0; 
            /* Arka plan ışığını maviye çektik */
            background-image: radial-gradient(circle at 50% -20%, rgba(59, 130, 246, 0.15) 0%, transparent 50%); 
            min-height: 100vh;
        }

        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }

        nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
        .logo { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; }
        .logo span { color: var(--primary); }

        .calc-card { 
            background: var(--surface); 
            border: 1px solid var(--border); 
            border-radius: 28px; 
            padding: 40px; 
            box-shadow: 0 25px 50px rgba(0,0,0,0.4);
            position: relative;
        }

        /* Başlık altı mavi çizgi */
        .calc-card h2::after {
            content: ""; display: block; width: 50px; height: 4px; background: var(--primary); margin-top: 10px; border-radius: 2px;
        }

        .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px; }
        label { color: var(--text-dim); font-size: 0.75rem; font-weight: 700; letter-spacing: 1px; margin-bottom: 8px; display: block; }
        
        input { 
            background: #020617; 
            border: 1px solid var(--border); 
            padding: 16px; 
            border-radius: 14px; 
            color: #fff; 
            font-size: 1.1rem; 
            width: 100%; 
            box-sizing: border-box; 
            transition: 0.3s; 
        }
        input:focus { border-color: var(--primary); outline: none; box-shadow: 0 0 15px var(--primary-glow); }

        .btn-calc { 
            background: var(--primary); 
            color: #fff; 
            border: none; 
            padding: 20px; 
            border-radius: 16px; 
            width: 100%; 
            font-weight: 800; 
            cursor: pointer; 
            font-size: 1.1rem; 
            transition: 0.3s; 
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        .btn-calc:hover { transform: translateY(-2px); box-shadow: 0 10px 25px var(--primary-glow); filter: brightness(1.1); }

        .res-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 30px; display: none; }
        
        .res-item { 
            background: rgba(255,255,255,0.02); 
            padding: 25px; 
            border-radius: 20px; 
            text-align: center; 
            border: 1px solid var(--border); 
        }
        
        /* Sonuç rakamlarını mavi yaptık */
        .res-item h2 { color: var(--primary); font-size: 2.2rem; margin: 10px 0; font-weight: 800; }
        .res-item h3 { color: #fff; margin: 5px 0; font-weight: 700; }

        @media (max-width: 600px) { .input-row { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
    <div class="container">
        <nav>
            <a href="/" class="logo">HESAP<span>360</span></a>
            <a href="/" style="color:var(--text-dim); text-decoration:none; font-weight: 600;"><i class="fa-solid fa-chevron-left"></i> Ana Sayfa</a>
        </nav>
        
        <div class="calc-card">
            <h2 style="margin-bottom:30px; font-weight:800;">Mevduat Getiri Analizi</h2>
            
            <div class="input-row">
                <div>
                    <label>ANAPARA (₺)</label>
                    <input type="number" id="capital" value="100000">
                </div>
                <div>
                    <label>VADE (GÜN)</label>
                    <input type="number" id="days" value="32">
                </div>
            </div>
            
            <div class="input-row">
                <div>
                    <label>YILLIK FAİZ ORANI (%)</label>
                    <input type="number" id="rate" value="45">
                </div>
                <div>
                    <label>STOPAJ / VERGİ (%)</label>
                    <input type="number" id="tax" value="5">
                </div>
            </div>
            
            <button class="btn-calc" onclick="calcM()">
                <i class="fa-solid fa-calculator"></i> HESAPLA VE ANALİZ ET
            </button>
            
            <div class="res-grid" id="resM">
                <div class="res-item" style="grid-column: span 2; border-color: var(--primary);">
                    <span style="color:var(--text-dim); font-size:0.85rem; font-weight:700; letter-spacing: 1px;">TOPLAM NET KAZANÇ</span>
                    <h2 id="net">0 ₺</h2>
                </div>
                <div class="res-item">
                    <span style="color:var(--text-dim); font-size:0.75rem; font-weight:700;">STOPAJ KESİNTİSİ</span>
                    <h3 id="taxV">0 ₺</h3>
                </div>
                <div class="res-item">
                    <span style="color:var(--text-dim); font-size:0.75rem; font-weight:700;">VADE SONU BAKİYE</span>
                    <h3 id="total">0 ₺</h3>
                </div>
            </div>
        </div>
    </div>

    <script>
        function calcM() {
            const c = parseFloat(document.getElementById('capital').value);
            const d = parseInt(document.getElementById('days').value);
            const r = parseFloat(document.getElementById('rate').value);
            const t = parseFloat(document.getElementById('tax').value);
            
            // Mevduat Formülü: (Anapara / 100) * (Faiz / 365) * Gün
            const gross = (c / 100) * (r / 365) * d;
            const taxVal = gross * (t / 100);
            const netVal = gross - taxVal;
            
            document.getElementById('net').innerText = Math.floor(netVal).toLocaleString('tr-TR') + " ₺";
            document.getElementById('taxV').innerText = Math.floor(taxVal).toLocaleString('tr-TR') + " ₺";
            document.getElementById('total').innerText = Math.floor(c + netVal).toLocaleString('tr-TR') + " ₺";
            
            document.getElementById('resM').style.display = 'grid';
        }
    </script>
</body>
</html>
