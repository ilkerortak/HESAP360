<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mevduat Getirisi | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root { --bg: #020617; --surface: #0f172a; --primary: #10b981; --border: rgba(255, 255, 255, 0.08); --text-dim: #94a3b8; }
        body { background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; margin: 0; background-image: radial-gradient(circle at 50% -20%, #064e3b33 0%, transparent 50%); }
        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
        .calc-card { background: var(--surface); border: 1px solid var(--border); border-radius: 24px; padding: 40px; box-shadow: 0 25px 50px rgba(0,0,0,0.5); }
        .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px; }
        label { color: var(--text-dim); font-size: 0.75rem; font-weight: 700; letter-spacing: 1px; margin-bottom: 8px; display: block; }
        input { background: #020617; border: 1px solid var(--border); padding: 16px; border-radius: 12px; color: #fff; font-size: 1.1rem; width: 100%; box-sizing: border-box; }
        .btn-calc { background: var(--primary); color: #fff; border: none; padding: 20px; border-radius: 16px; width: 100%; font-weight: 800; cursor: pointer; font-size: 1.1rem; }
        .res-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 30px; display: none; }
        .res-item { background: rgba(0,0,0,0.3); padding: 20px; border-radius: 15px; text-align: center; border: 1px solid var(--border); }
    </style>
</head>
<body>
    <div class="container">
        <nav style="margin-bottom: 40px;"><a href="/" style="font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none;">HESAP<span style="color:var(--primary)">360</span></a></nav>
        <div class="calc-card">
            <div class="input-row"><div><label>YATIRIM TUTARI (₺)</label><input type="number" id="capital" placeholder="Örn: 100000"></div><div><label>VADE (GÜN)</label><input type="number" id="days" value="32"></div></div>
            <div class="input-row"><div><label>FAİZ ORANI (%)</label><input type="number" id="rate" value="45"></div><div><label>STOPAJ (%)</label><input type="number" id="tax" value="5"></div></div>
            <button class="btn-calc" onclick="calcM()">HESAPLA</button>
            <div class="res-grid" id="resM">
                <div class="res-item" style="grid-column: span 2;"><span style="color:var(--text-dim); font-size:0.8rem;">NET GETİRİ</span><h2 id="net" style="color:var(--primary)">0 ₺</h2></div>
                <div class="res-item"><span style="color:var(--text-dim); font-size:0.8rem;">VERGİ (STOPAJ)</span><h3 id="taxV">0 ₺</h3></div>
                <div class="res-item"><span style="color:var(--text-dim); font-size:0.8rem;">TOPLAM PARA</span><h3 id="total">0 ₺</h3></div>
            </div>
        </div>
    </div>
    <script>
        function calcM() {
            const c = parseFloat(document.getElementById('capital').value);
            const d = parseInt(document.getElementById('days').value);
            const r = parseFloat(document.getElementById('rate').value);
            const t = parseFloat(document.getElementById('tax').value);
            const gross = (c / 100) * (r / 365) * d;
            const taxVal = gross * (t / 100);
            const netVal = gross - taxVal;
            document.getElementById('net').innerText = netVal.toLocaleString('tr-TR', {maximumFractionDigits:2}) + " ₺";
            document.getElementById('taxV').innerText = taxVal.toLocaleString('tr-TR', {maximumFractionDigits:2}) + " ₺";
            document.getElementById('total').innerText = (c + netVal).toLocaleString('tr-TR', {maximumFractionDigits:2}) + " ₺";
            document.getElementById('resM').style.display = 'grid';
        }
    </script>
</body>
</html>
