<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mevduat Getirisi Hesapla | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root { --main: #6366f1; --bg: #0f172a; --glass: #1e293b; --border: rgba(255, 255, 255, 0.1); }
        body { background: var(--bg); color: #fff; font-family: 'Inter', sans-serif; margin: 0; }
        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
        
        /* Hesaplama Paneli */
        .panel { 
            background: var(--glass); border-radius: 24px; padding: 30px; 
            margin-bottom: 30px; display: grid; grid-template-columns: 1fr 1fr; gap: 30px;
            border: 1px solid var(--border);
        }
        .input-group label { display: block; font-size: 0.8rem; color: #94a3b8; margin-bottom: 10px; font-weight: 600; text-transform: uppercase; }
        .input-group b { font-size: 1.4rem; color: var(--main); }
        input[type="range"] { width: 100%; height: 6px; background: #334155; border-radius: 5px; appearance: none; margin-top: 15px; }
        input[type="range"]::-webkit-slider-thumb { appearance: none; width: 20px; height: 20px; background: #fff; border-radius: 50%; cursor: pointer; border: 4px solid var(--main); }

        /* Banka Listesi */
        .bank-card { 
            background: var(--glass); border: 1px solid var(--border); border-radius: 22px; 
            padding: 25px; margin-bottom: 15px; display: flex; align-items: center; justify-content: space-between;
            transition: 0.3s ease;
        }
        .bank-card:hover { border-color: var(--main); transform: translateX(5px); }
        .logo-box { background: #fff; width: 120px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; padding: 5px; }
        .logo-box img { max-width: 90%; max-height: 80%; object-fit: contain; }
        
        .val { text-align: center; }
        .val small { color: #64748b; font-size: 0.75rem; display: block; margin-bottom: 5px; }
        .val b { font-size: 1.15rem; color: #f8fafc; }
        .net-gain { color: #10b981 !important; } /* Net kazanç yeşil */

        .btn-open { background: var(--main); color: #fff; text-decoration: none; padding: 12px 25px; border-radius: 14px; font-weight: 700; font-size: 0.85rem; }
    </style>
</head>
<body>
    <div class="container">
        <a href="/" style="color:#94a3b8; text-decoration:none; font-size:0.9rem; display: inline-flex; align-items: center; gap: 5px;">
            <i class="fa-solid fa-arrow-left"></i> Ana Sayfaya Dön
        </a>
        <h2 style="margin: 25px 0; font-weight: 800; letter-spacing: -1px; font-size: 2rem;">Mevduat Getiri Analizi</h2>

        <div class="panel">
            <div class="input-group">
                <label>Anapara (₺)</label>
                <b id="capTxt">50.000 ₺</b>
                <input type="range" id="capital" min="1000" max="5000000" step="1000" value="50000" oninput="calcMevduat()">
            </div>
            <div class="input-group">
                <label>Vade (Gün)</label>
                <b id="dayTxt">32 Gün</b>
                <input type="range" id="days" min="1" max="365" step="1" value="32" oninput="calcMevduat()">
            </div>
        </div>

        <div id="bankList">
            <% banks.forEach(bank => { %>
                <div class="bank-card" data-mrate="45"> 
                    <div class="logo-box"><img src="<%= bank.logo %>" alt="<%= bank.ad %>"></div>
                    <div class="val">
                        <small>FAİZ ORANI</small>
                        <b>%45</b>
                    </div>
                    <div class="val">
                        <small>NET GETİRİ</small>
                        <b class="net-gain gainVal">0 ₺</b>
                    </div>
                    <div class="val">
                        <small>TOPLAM TUTAR</small>
                        <b class="totalVal">0 ₺</b>
                    </div>
                    <a href="#" class="btn-open">Hesap Aç</a>
                </div>
            <% }) %>
        </div>
    </div>

    <script>
        function calcMevduat() {
            const capital = parseFloat(document.getElementById('capital').value);
            const days = parseInt(document.getElementById('days').value);
            
            document.getElementById('capTxt').innerText = capital.toLocaleString('tr-TR') + " ₺";
            document.getElementById('dayTxt').innerText = days + " Gün";

            document.querySelectorAll('.bank-card').forEach(card => {
                const rate = parseFloat(card.getAttribute('data-mrate'));
                
                // Mevduat Formülü: (Anapara / 100) * (Faiz / 365) * Gün
                // %5 Stopaj kesintisi düşülmüştür.
                const grossGain = (capital / 100) * (rate / 365) * days;
                const netGain = grossGain * 0.95; 
                const total = capital + netGain;

                card.querySelector('.gainVal').innerText = Math.floor(netGain).toLocaleString('tr-TR') + " ₺";
                card.querySelector('.totalVal').innerText = Math.floor(total).toLocaleString('tr-TR') + " ₺";
            });
        }
        // Sayfa yüklendiğinde ilk hesaplamayı yap
        window.onload = calcMevduat;
    </script>
</body>
</html>
