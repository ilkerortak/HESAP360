<nav class="nav-container">
    <a href="/" class="logo">HESAP<span>360</span></a>
    <div class="nav-right">
        <button id="theme-toggle" class="theme-btn">
            <i class="fa-solid fa-moon"></i>
        </button>
    </div>
</nav>

<style>
    :root { 
        --bg: #ffffff; --surface: #f5f7fa; --text: #1d1d1f; --blue: #0066ff; --border: #d2d2d7; 
    }
    [data-theme="dark"] { 
        --bg: #000000; --surface: #1c1c1e; --text: #f5f5f7; --blue: #0a84ff; --border: #38383a; 
    }

    body { background: var(--bg); color: var(--text); transition: 0.3s ease; margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
    .nav-container { display: flex; justify-content: space-between; align-items: center; padding: 20px 40px; border-bottom: 1px solid var(--border); }
    .logo { font-size: 1.5rem; font-weight: 800; text-decoration: none; color: var(--text); letter-spacing: -1px; }
    .logo span { color: var(--blue); }
    
    .theme-btn { background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 10px 15px; border-radius: 12px; cursor: pointer; font-size: 1.1rem; transition: 0.2s; }
    .theme-btn:hover { transform: scale(1.05); }

    .back-link { display: inline-flex; align-items: center; gap: 8px; color: var(--blue); text-decoration: none; font-weight: 600; margin-bottom: 30px; font-size: 0.95rem; }
    .back-link:hover { text-decoration: underline; }
</style>

<script>
    const btn = document.getElementById('theme-toggle');
    const currentTheme = localStorage.getItem('theme');
    if (currentTheme) {
        document.documentElement.setAttribute('data-theme', currentTheme);
        btn.innerHTML = currentTheme === 'dark' ? '<i class="fa-solid fa-sun"></i>' : '<i class="fa-solid fa-moon"></i>';
    }

    btn.addEventListener('click', () => {
        let theme = document.documentElement.getAttribute('data-theme');
        if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'light');
            localStorage.setItem('theme', 'light');
            btn.innerHTML = '<i class="fa-solid fa-moon"></i>';
        } else {
            document.documentElement.setAttribute('data-theme', 'dark');
            localStorage.setItem('theme', 'dark');
            btn.innerHTML = '<i class="fa-solid fa-sun"></i>';
        }
    });
</script>
