</div> <script>
    // İlçe çekme fonksiyonu - Plaka koduna göre kesin arama yapar
    async function ilceGuncelle() {
        const ilSelect = document.getElementById('il-secim');
        const selectedOption = ilSelect.options[ilSelect.selectedIndex];
        const plaka = selectedOption.getAttribute('data-plaka');
        const ilceSelect = document.getElementById('ilce-secim');
        
        if (!plaka) {
            ilceSelect.innerHTML = '<option value="">Önce İl Seçiniz</option>';
            return;
        }

        ilceSelect.innerHTML = '<option value="">Yükleniyor...</option>';

        try {
            const response = await fetch(`https://turkiyeapi.dev/api/v1/provinces/${plaka}`);
            const data = await response.json();
            
            if (data.status === "OK") {
                const ilceler = data.data.districts;
                ilceSelect.innerHTML = '<option value="">Tüm İlçeler</option>';
                
                ilceler.sort((a, b) => a.name.localeCompare(b.name, 'tr')).forEach(item => {
                    const opt = document.createElement('option');
                    // API parametre uyumu için Türkçe karakter normalizasyonu
                    const normalizeVal = item.name.replace(/İ/g, 'I').replace(/ı/g, 'i')
                                                 .replace(/Ş/g, 'S').replace(/ş/g, 's')
                                                 .replace(/Ğ/g, 'G').replace(/ğ/g, 'g')
                                                 .replace(/Ü/g, 'U').replace(/ü/g, 'u')
                                                 .replace(/Ö/g, 'O').replace(/ö/g, 'o')
                                                 .replace(/Ç/g, 'C').replace(/ç/g, 'c')
                                                 .toUpperCase();
                    opt.value = normalizeVal;
                    opt.innerHTML = item.name;
                    ilceSelect.appendChild(opt);
                });
            } else {
                ilceSelect.innerHTML = '<option value="">İlçe bulunamadı</option>';
            }
        } catch (error) {
            console.error("İlçe çekme hatası:", error);
            ilceSelect.innerHTML = '<option value="">Hata oluştu</option>';
        }
    }

    // Yönlendirme fonksiyonu
    function gitEczaneye() {
        const il = document.getElementById('il-secim').value;
        const ilce = document.getElementById('ilce-secim').value;
        if (il) {
            const url = ilce ? `/eczaneler/${il}/${ilce}` : `/eczaneler/${il}`;
            window.location.href = url;
        } else {
            alert("Lütfen bir il seçiniz.");
        }
    }
</script>
