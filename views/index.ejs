<div class="apple-card" style="text-align: center;">
    <h1 style="font-size: 2.2rem; font-weight: 800; margin-bottom: 10px;">Nöbetçi Eczane Bul</h1>
    <p style="opacity: 0.6; margin-bottom: 30px;">İl ve ilçe seçerek anlık listeye ulaşın.</p>

    <div style="display: flex; flex-direction: column; gap: 15px;">
        <select id="il-secim" onchange="ilceGuncelle()" style="padding: 15px; border-radius: 15px; border: 1px solid var(--border); background: var(--bg); color: var(--text); font-size: 1rem; cursor: pointer;">
            <option value="">İl Seçiniz</option>
            <option value="sakarya">Sakarya</option>
            <option value="istanbul">İstanbul</option>
            <option value="ankara">Ankara</option>
        </select>

        <select id="ilce-secim" style="padding: 15px; border-radius: 15px; border: 1px solid var(--border); background: var(--bg); color: var(--text); font-size: 1rem; cursor: pointer;">
            <option value="">Önce İl Seçiniz</option>
        </select>

        <button onclick="gitEczaneye()" style="padding: 18px; border-radius: 15px; border: none; background: var(--blue); color: white; font-weight: 700; font-size: 1.1rem; cursor: pointer; margin-top: 10px;">
            Eczaneleri Listele →
        </button>
    </div>
</div>

<script>
    const ilceler = {
        sakarya: ["Adapazarı", "Serdivan", "Erenler", "Hendek", "Akyazı", "Sapanca", "Karasu", "Geyve", "Arifiye"],
        istanbul: ["Kadıköy", "Beşiktaş", "Üsküdar", "Şişli", "Fatih"],
        ankara: ["Çankaya", "Keçiören", "Yenimahalle", "Mamak"]
    };

    function ilceGuncelle() {
        const il = document.getElementById('il-secim').value;
        const ilceSelect = document.getElementById('ilce-secim');
        ilceSelect.innerHTML = '<option value="">İlçe Seçiniz</option>';
        
        if (il && ilceler[il]) {
            ilceler[il].forEach(ilce => {
                const opt = document.createElement('option');
                opt.value = ilce.toLowerCase();
                opt.innerHTML = ilce;
                ilceSelect.appendChild(opt);
            });
        }
    }

    function gitEczaneye() {
        const il = document.getElementById('il-secim').value;
        const ilce = document.getElementById('ilce-secim').value;
        if (il && ilce) {
            window.location.href = `/eczaneler/${il}/${ilce}`;
        } else {
            alert("Lütfen il ve ilçe seçiniz.");
        }
    }
</script>
