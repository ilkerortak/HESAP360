<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Hesap360 | Finansal Karşılaştırma</title>
    <style>
        body { background: #020617; color: white; font-family: sans-serif; }
        .ticker { background: #0f172a; padding: 10px; border-bottom: 1px solid #1e293b; }
    </style>
</head>
<body>
    <div class="ticker">
        <% if (locals.data) { %>
            USD: <%= data.market.usd %> | EUR: <%= data.market.eur %>
        <% } else { %>
            Veriler yükleniyor...
        <% } %>
    </div>
    <h1>Finansal İhtiyaçlarınız İçin Hesap360</h1>
    <a href="/kredi">Kredileri Karşılaştır</a>
</body>
</html>
