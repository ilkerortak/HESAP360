        <p style="color: #888; font-size: 0.95rem; line-height: 1.6;">Resmi tatiller, hafta sonları ve gece saatlerinde size en yakın eczaneyi bulmak artık çok kolay. Antalya'dan Sakarya'ya, İstanbul'dan Ankara'ya tüm Türkiye kapsama alanımızda.</p>
    </div>
</div>

<script>
    async function ilceGuncelle() {
        const il = document.getElementById('il-secim').value;
        const ilceSelect = document.getElementById('ilce-secim');
        
        if (!il) {
            ilceSelect.innerHTML = '<option value="">Önce İl Seçiniz</option>';
            return;
        }

        ilceSelect.innerHTML = '<option value="">Yükleniyor...</option>';

        try {
            const response = await fetch(`https://turkiyeapi.dev/api/v1/provinces?name=${il}`);
            const data = await response.json();
            
            if (data.status === "OK" && data.data.length > 0) {
                const ilceler = data.data[0].districts;
                ilceSelect.innerHTML = '<option value="">İlçe Seçiniz (Tümü için boş bırakın)</option>';
                
                ilceler.sort((a, b) => a.name.localeCompare(b.name)).forEach(item => {
                    const opt = document.createElement('option');
                    // API parametre uyumu için temizleme
                    opt.value = item.name.replace(/İ/g, 'I').replace(/ı/g, 'i').toUpperCase();
                    opt.innerHTML = item.name;
                    ilceSelect.appendChild(opt);
                });
            } else {
                ilceSelect.innerHTML = '<option value="">İlçe bulunamadı</option>';
            }
        } catch (error) {
            console.error("İlçe çekme hatası:", error);
            ilceSelect.innerHTML = '<option value="">Hata oluştu</option>';
        }
    }

    function gitEczaneye() {
        const il = document.getElementById('il-secim').value;
        const ilce = document.getElementById('ilce-secim').value;
        if (il) {
            const url = ilce ? `/eczaneler/${il}/${ilce}` : `/eczaneler/${il}`;
            window.location.href = url;
        } else {
            alert("Lütfen bir il seçiniz.");
        }
    }
</script>
