<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hesap360 | Finansal Karşılaştırma Merkezi</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root { 
            --bg: #020617; --surface: #0f172a; --primary: #3b82f6; 
            --primary-glow: rgba(59, 130, 246, 0.2); --border: rgba(255, 255, 255, 0.08); --text-dim: #94a3b8; 
        }
        body { 
            background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; margin: 0; 
            background-image: radial-gradient(circle at 50% -20%, var(--primary-glow) 0%, transparent 50%);
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        
        /* Ticker - Canlı Band */
        .ticker { background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); padding: 12px 0; font-size: 0.85rem; }
        .ticker span { margin-right: 25px; font-weight: 700; color: var(--text-dim); }
        .ticker b { color: var(--primary); margin-left: 5px; }

        nav { padding: 30px 0; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 1.8rem; font-weight: 800; text-decoration: none; color: #fff; }
        .logo span { color: var(--primary); }

        .hero { text-align: center; padding: 60px 0 40px; }
        .hero h1 { font-size: 2.2rem; font-weight: 800; }

        /* Kategori Grid */
        .grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 15px; margin-bottom: 50px; }
        .card { 
            background: var(--surface); border: 1px solid var(--border); border-radius: 20px; 
            padding: 30px 10px; text-align: center; text-decoration: none; color: inherit; transition: 0.3s;
        }
        .card:hover { border-color: var(--primary); transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .card i { font-size: 2rem; color: var(--primary); margin-bottom: 15px; display: block; }
        .card span { font-size: 0.9rem; font-weight: 700; }

        /* Banka Fırsatları - Orijinal Logolar */
        .deals-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 40px; }
        .deal-item { 
            background: var(--surface); border: 1px solid var(--border); border-radius: 24px; padding: 25px; 
            display: flex; align-items: center; gap: 20px; transition: 0.3s;
        }
        .deal-item img { width: 80px; height: auto; object-fit: contain; background: #fff; padding: 10px; border-radius: 12px; }
        .deal-item h3 { margin: 0; font-size: 1.1rem; }
        .deal-item p { margin: 5px 0 0 0; color: var(--text-dim); font-size: 0.85rem; }

        @media (max-width: 900px) { .grid { grid-template-columns: repeat(3, 1fr); } .deals-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

<div class="ticker">
    <div class="container">
        <span>USD/TRY <b><%= data.rates.usd %></b></span>
        <span>EUR/TRY <b><%= data.rates.eur %></b></span>
        <span>ALTIN (GR) <b><%= data.rates.gold %></b></span>
        <span style="float:right;"><i class="fa-solid fa-circle" style="color:#10b981; font-size:8px;"></i> CANLI</span>
    </div>
</div>

<div class="container">
    <nav><a href="/" class="logo">HESAP<span>360</span></a></nav>

    <div class="hero"><h1>Finansal ihtiyaçlarınız için en avantajlı çözümler</h1></div>

    <div class="grid">
        <a href="/kredi" class="card"><i class="fa-solid fa-hand-holding-dollar"></i><span>İhtiyaç Kredisi</span></a>
        <a href="/kredi-karti" class="card"><i class="fa-solid fa-credit-card"></i><span>Kredi Kartı</span></a>
        <a href="/mevduat" class="card"><i class="fa-solid fa-piggy-bank"></i><span>Mevduat</span></a>
        <a href="/kredi" class="card"><i class="fa-solid fa-house"></i><span>Konut Kredisi</span></a>
        <a href="/kredi" class="card"><i class="fa-solid fa-car"></i><span>Taşıt Kredisi</span></a>
        <a href="/kredi-limit" class="card"><i class="fa-solid fa-gauge-high"></i><span>Limit Analizi</span></a>
    </div>

    <h2 style="font-weight: 800; margin-top: 60px;">En Avantajlı Fırsatlar</h2>
    <div class="deals-grid">
        <% data.kredi.slice(0, 2).forEach(bank => { %>
            <div class="deal-item">
                <img src="<%= bank.logo %>" alt="<%= bank.ad %>">
                <div>
                    <h3><%= bank.ad %> Hoşgeldin Faizi</h3>
                    <p>%<%= bank.oran %> faiz oranıyla kredi fırsatı seni bekliyor.</p>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<footer style="margin-top:100px; padding:40px 0; text-align:center; color:var(--text-dim); border-top: 1px solid var(--border);">
    <p>© 2026 Hesap360 Master Pro | Profesyonel Finans Portalı</p>
</footer>

</body>
</html>
