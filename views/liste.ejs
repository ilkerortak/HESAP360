<div style="margin-bottom: 30px; text-align: left;">
    <a href="/" style="text-decoration: none; color: #007AFF; font-weight: 600; display: flex; align-items: center; gap: 5px;">
        <span style="font-size: 1.2rem;">←</span> Geri Dön
    </a>
    <h1 style="margin-top: 15px; font-weight: 800; color: #fff; font-size: 2.2rem; letter-spacing: -1px;">
        <%= il %> <span style="color: #007AFF;">Nöbetçi Eczaneler</span>
    </h1>
</div>

<div class="results-grid">
    <% if (eczaneler && eczaneler.length > 0) { %>
        <% eczaneler.forEach(e => { %>
            <div class="apple-card" style="display: flex; flex-direction: column; justify-content: space-between; gap: 20px; background: rgba(28, 28, 30, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.08); padding: 30px; border-radius: 25px; box-shadow: 0 15px 30px rgba(0,0,0,0.2);">
                
                <div>
                    <h2 style="margin: 0; color: #007AFF; font-size: 1.5rem; font-weight: 800; letter-spacing: -0.5px;"><%= e.ad %></h2>
                    <div style="margin-top: 12px; display: flex; gap: 8px;">
                        <span style="font-size: 1.1rem; opacity: 0.9;">📍</span>
                        <p style="color: rgba(255,255,255,0.7); margin: 0; line-height: 1.5; font-size: 1rem;"><%= e.adres %></p>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <a href="https://www.google.com/maps/dir/?api=1&destination=<%= encodeURIComponent(e.ad + ' ' + e.adres) %>" 
                       target="_blank" 
                       style="display: flex; align-items: center; justify-content: center; gap: 6px; background: rgba(255, 255, 255, 0.05); color: #fff; padding: 14px 5px; border-radius: 15px; text-decoration: none; font-weight: 700; border: 1px solid rgba(255, 255, 255, 0.1); font-size: 0.85rem; transition: 0.3s;">
                        <span>📍</span> Yol Tarifi
                    </a>

                    <a href="tel:<%= e.tel %>" 
                       style="display: flex; align-items: center; justify-content: center; gap: 6px; background: #34C759; color: white; padding: 14px 5px; border-radius: 15px; text-decoration: none; font-weight: 700; font-size: 0.85rem; transition: 0.3s; box-shadow: 0 4px 15px rgba(52, 199, 89, 0.2);">
                        <span>📞</span> Eczane'yi Ara
                    </a>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <div class="apple-card" style="grid-column: 1/-1; text-align: center; padding: 60px; background: rgba(255, 255, 255, 0.02); border-radius: 30px; border: 1px dashed rgba(255, 255, 255, 0.1);">
            <p style="opacity: 0.5; font-size: 1.1rem; color: #fff;">Üzgünüz, şu an bu bölge için nöbetçi eczane verisi alınamadı.</p>
            <a href="/" style="color: #007AFF; font-weight: bold; text-decoration: none; margin-top: 10px; display: inline-block;">Başka bir arama yapın →</a>
        </div>
    <% } %>
</div>

<style>
    .results-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
        margin-bottom: 50px;
    }
    
    /* Masaüstü ve Tablet Görünümü */
    @media (min-width: 768px) {
        .results-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (min-width: 1024px) {
        .results-grid { grid-template-columns: 1fr 1fr 1fr; }
    }

    /* Kart Hover Efekti */
    .apple-card {
        transition: all 0.3s ease;
    }
    .apple-card:hover {
        transform: translateY(-5px);
        border-color: rgba(0, 122, 255, 0.4);
        background: rgba(44, 44, 46, 0.8);
    }

    /* Buton Hover Efekti */
    .results-grid a:hover {
        opacity: 0.9;
        transform: scale(1.02);
    }
</style>
