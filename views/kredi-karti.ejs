<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kart Analizi | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #020617; --surface: #0f172a; --primary: #3b82f6; --border: rgba(255, 255, 255, 0.08); --text-dim: #94a3b8; }
        body { background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; margin: 0; background-image: radial-gradient(circle at 50% -20%, rgba(59, 130, 246, 0.15) 0%, transparent 50%); }
        .container { max-width: 800px; margin: 0 auto; padding: 40px 20px; }
        .card { background: var(--surface); border: 1px solid var(--border); border-radius: 24px; padding: 40px; }
        input { width: 100%; background: #020617; border: 1px solid var(--border); padding: 15px; border-radius: 12px; color: #fff; margin-top: 10px; font-size: 1.1rem; }
        .btn { background: var(--primary); color: #fff; border: none; padding: 18px; border-radius: 12px; width: 100%; font-weight: 800; cursor: pointer; margin-top: 20px; }
        .res { margin-top: 30px; display: grid; grid-template-columns: 1fr 1fr; gap: 15px; display: none; }
        .res-i { background: rgba(255,255,255,0.03); padding: 20px; border-radius: 15px; text-align: center; border: 1px solid var(--border); }
    </style>
</head>
<body>
    <div class="container">
        <nav style="margin-bottom:30px;"><a href="/" style="color:#fff; text-decoration:none; font-weight:800; font-size:1.5rem;">HESAP<span>360</span></a></nav>
        <div class="card">
            <h2 style="margin:0 0 20px 0;">Kredi Kartı Borç Analizi</h2>
            <label style="color:var(--text-dim); font-size:0.8rem;">DÖNEM BORCU (₺)</label>
            <input type="number" id="debt" value="25000">
            <button class="btn" onclick="calcCard()">ANALİZ ET</button>
            <div class="res" id="rBox">
                <div class="res-i"><span style="color:var(--text-dim); font-size:0.7rem;">ASGARİ ÖDEME (%20)</span><h2 style="color:var(--primary)" id="min">0 ₺</h2></div>
                <div class="res-i"><span style="color:var(--text-dim); font-size:0.7rem;">KALAN BORÇ</span><h2 id="rem">0 ₺</h2></div>
                <div class="res-i" style="grid-column: span 2;"><p style="font-size:0.8rem; color:var(--text-dim);">*Asgari ödeme oranı 25.000 TL altı limitler için %20, üstü için %40 olarak hesaplanır.</p></div>
            </div>
        </div>
    </div>
    <script>
        function calcCard() {
            const d = parseFloat(document.getElementById('debt').value);
            const rate = d > 25000 ? 0.4 : 0.2;
            const min = d * rate;
            document.getElementById('min').innerText = min.toLocaleString() + " ₺";
            document.getElementById('rem').innerText = (d - min).toLocaleString() + " ₺";
            document.getElementById('rBox').style.display = 'grid';
        }
    </script>
</body>
</html>
