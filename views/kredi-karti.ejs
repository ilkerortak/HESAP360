<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Kredi Kartı Analizi | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #020617; --surface: #0f172a; --primary: #3b82f6; --border: rgba(255, 255, 255, 0.08); --text-dim: #94a3b8; }
        body { background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; margin: 0; }
        .container { max-width: 800px; margin: 0 auto; padding: 60px 20px; }
        .card { background: var(--surface); border: 1px solid var(--border); border-radius: 28px; padding: 40px; box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
        .input-group { margin-bottom: 25px; }
        label { display: block; margin-bottom: 10px; color: var(--text-dim); font-size: 0.85rem; font-weight: 700; }
        input { width: 100%; background: #020617; border: 1px solid var(--border); padding: 15px; border-radius: 12px; color: #fff; font-size: 1.1rem; box-sizing: border-box; }
        .btn { background: var(--primary); color: #fff; border: none; padding: 18px; border-radius: 12px; width: 100%; font-weight: 800; cursor: pointer; transition: 0.3s; margin-top: 10px; }
        .btn:hover { opacity: 0.9; transform: translateY(-2px); }
        .results { margin-top: 40px; display: none; grid-template-columns: 1fr 1fr; gap: 20px; }
        .res-item { background: rgba(59, 130, 246, 0.05); border: 1px solid var(--border); padding: 25px; border-radius: 20px; text-align: center; }
        .res-item h2 { color: var(--primary); margin: 10px 0 0 0; }
    </style>
</head>
<body>
    <div class="container">
        <a href="/" style="color:var(--primary); text-decoration:none; font-weight:700; display:inline-block; margin-bottom:20px;">← Ana Sayfaya Dön</a>
        <div class="card">
            <h2 style="margin-top:0;">Kredi Kartı Borç Hesaplama</h2>
            <p style="color:var(--text-dim); font-size:0.9rem; margin-bottom:30px;">Güncel asgari ödeme oranları ve gecikme faizine göre analiz edin.</p>
            
            <div class="input-group">
                <label>TOPLAM EKSTRE BORCU (₺)</label>
                <input type="number" id="debt" placeholder="Örn: 25000">
            </div>

            <button class="btn" onclick="analyzeCard()">BORCU ANALİZ ET</button>

            <div class="results" id="resBox">
                <div class="res-item">
                    <small style="color:var(--text-dim)">ASGARI ÖDEME</small>
                    <h2 id="minPay">0 ₺</h2>
                </div>
                <div class="res-item">
                    <small style="color:var(--text-dim)">KALAN BORÇ</small>
                    <h2 id="remain">0 ₺</h2>
                </div>
                <div class="res-item" style="grid-column: span 2; text-align: left;">
                    <p style="font-size: 0.8rem; color: var(--text-dim); margin: 0;">
                        * 25.000 TL ve altı limitli kartlarda asgari oran %20, üstünde %40 olarak hesaplanmıştır.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script>
        function analyzeCard() {
            const debt = parseFloat(document.getElementById('debt').value);
            if(!debt) return alert("Lütfen borç tutarını girin.");

            const rate = debt > 25000 ? 0.4 : 0.2;
            const min = debt * rate;
            
            document.getElementById('minPay').innerText = Math.floor(min).toLocaleString() + " ₺";
            document.getElementById('remain').innerText = Math.floor(debt - min).toLocaleString() + " ₺";
            document.getElementById('resBox').style.display = 'grid';
        }
    </script>
</body>
</html>
