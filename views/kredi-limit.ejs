<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Limit Analizi | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --bg: #020617;
            --surface: #0f172a;
            --primary: #3b82f6;
            --border: rgba(255, 255, 255, 0.08);
            --text-dim: #94a3b8;
        }

        body { 
            background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; margin: 0;
            background-image: radial-gradient(circle at 50% -20%, #1e40af44 0%, transparent 60%);
            min-height: 100vh;
        }

        .container { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }

        nav { margin-bottom: 50px; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; }
        .logo span { color: var(--primary); }

        .main-panel { display: grid; grid-template-columns: 1fr 320px; gap: 30px; }

        /* Analiz Formu */
        .glass-card {
            background: var(--surface); border: 1px solid var(--border); border-radius: 24px;
            padding: 40px; box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
        }

        .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px; }
        .input-group { display: flex; flex-direction: column; gap: 8px; }
        label { color: var(--text-dim); font-size: 0.75rem; font-weight: 700; letter-spacing: 1px; }
        
        input {
            background: #020617; border: 1px solid var(--border); padding: 16px; 
            border-radius: 12px; color: #fff; font-size: 1.1rem; transition: 0.3s;
        }
        input:focus { border-color: var(--primary); outline: none; box-shadow: 0 0 15px rgba(59, 130, 246, 0.2); }

        .btn-main {
            width: 100%; background: var(--primary); color: #fff; border: none; padding: 20px;
            border-radius: 16px; font-size: 1.1rem; font-weight: 800; cursor: pointer;
            transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 10px;
        }
        .btn-main:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3); }

        /* Sonuç Paneli */
        #resultContainer { display: none; margin-top: 30px; animation: slideUp 0.5s ease-out; }
        @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .res-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .res-card { background: rgba(0,0,0,0.3); border: 1px solid var(--border); padding: 25px; border-radius: 20px; text-align: center; }
        .res-val { display: block; font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-top: 5px; }

        /* Sidebar */
        .sidebar { display: flex; flex-direction: column; gap: 20px; }
        .side-box { background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border); padding: 20px; border-radius: 18px; font-size: 0.85rem; }
        .side-box i { color: var(--primary); margin-bottom: 10px; display: block; font-size: 1.2rem; }

        @media (max-width: 800px) { .main-panel { grid-template-columns: 1fr; } .input-row { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

<div class="container">
    <nav>
        <a href="/" class="logo">HESAP<span>360</span></a>
        <a href="/" style="color: var(--text-dim); text-decoration: none; font-size: 0.9rem;"><i class="fa-solid fa-arrow-left"></i> Geri</a>
    </nav>

    <div class="main-panel">
        <div class="glass-card">
            <h2 style="margin-bottom: 30px; font-weight: 800;">Limit Analizi</h2>
            <div class="input-row">
                <div class="input-group">
                    <label>AYLIK NET GELİR (₺)</label>
                    <input type="number" id="income" placeholder="Örn: 50000">
                </div>
                <div class="input-group">
                    <label>TOPLAM AYLIK BORÇ (₺)</label>
                    <input type="number" id="debts" placeholder="Örn: 8500">
                </div>
            </div>
            
            <div class="input-row">
                <div class="input-group">
                    <label>VADE (AY)</label>
                    <input type="number" id="term" value="12">
                </div>
                <div class="input-group">
                    <label>KREDİ NOTU (TAHMİNİ)</label>
                    <input type="number" id="score" placeholder="Örn: 1500">
                </div>
            </div>

            <button class="btn-main" onclick="analyze()">
                <i class="fa-solid fa-wand-magic-sparkles"></i> STRATEJİYİ ANALİZ ET
            </button>

            <div id="resultContainer">
                <div class="res-grid">
                    <div class="res-card" style="grid-column: span 2; border-color: var(--primary);">
                        <span style="font-size: 0.8rem; color: var(--text-dim);">TAHMİNİ MAKSİMUM LİMİT</span>
                        <span class="res-val" id="resLimit">0 ₺</span>
                    </div>
                    <div class="res-card">
                        <span style="font-size: 0.7rem; color: var(--text-dim);">ÖDENEBİLİR TAKSİT</span>
                        <span class="res-val" id="resInstallment" style="font-size: 1.3rem;">0 ₺</span>
                    </div>
                    <div class="res-card">
                        <span style="font-size: 0.7rem; color: var(--text-dim);">BORÇ/GELİR ORANI</span>
                        <span class="res-val" id="resRatio" style="font-size: 1.3rem;">%0</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="sidebar">
            <div class="side-box">
                <i class="fa-solid fa-shield-halved"></i>
                <p><b>Banka Rasyosu:</b> Bankalar aylık ödemelerinizin gelirinizin %50'sini aşmamasını bekler.</p>
            </div>
            <div class="side-box">
                <i class="fa-solid fa-circle-info"></i>
                <p>Hesaplama 2026 yılı güncel faiz projeksiyonları ile yapılmaktadır.</p>
            </div>
        </div>
    </div>
</div>

<script>
    function analyze() {
        const income = parseFloat(document.getElementById('income').value);
        const debts = parseFloat(document.getElementById('debts').value) || 0;
        const term = parseInt(document.getElementById('term').value) || 12;
        
        if(!income) return alert("Gelir alanını doldurunuz.");

        const availableMonthly = (income * 0.5) - debts;
        const monthlyRate = 0.0389; 
        const limit = availableMonthly > 0 ? availableMonthly * ((1 - Math.pow(1 + monthlyRate, -term)) / monthlyRate) : 0;
        const ratio = (debts / income) * 100;

        document.getElementById('resLimit').innerText = Math.floor(limit).toLocaleString('tr-TR') + " ₺";
        document.getElementById('resInstallment').innerText = (availableMonthly > 0 ? Math.floor(availableMonthly).toLocaleString('tr-TR') : 0) + " ₺";
        document.getElementById('resRatio').innerText = "%" + ratio.toFixed(1);
        document.getElementById('resultContainer').style.display = 'block';
    }
</script>

</body>
</html>
