<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Kredi Limiti Tahmini | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #020617; --surface: #0f172a; --primary: #3b82f6; --border: rgba(255, 255, 255, 0.08); --text-dim: #94a3b8; }
        body { background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: #fff; margin: 0; }
        .container { max-width: 800px; margin: 0 auto; padding: 60px 20px; }
        .card { background: var(--surface); border: 1px solid var(--border); border-radius: 28px; padding: 40px; }
        .input-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; color: var(--text-dim); font-size: 0.85rem; font-weight: 700; }
        input { width: 100%; background: #020617; border: 1px solid var(--border); padding: 15px; border-radius: 12px; color: #fff; box-sizing: border-box; }
        .gauge-container { margin-top: 40px; text-align: center; display: none; }
        .limit-box { background: linear-gradient(135deg, var(--primary) 0%, #1d4ed8 100%); padding: 30px; border-radius: 20px; margin-top: 20px; }
        .limit-box h1 { margin: 10px 0; font-size: 2.5rem; }
    </style>
</head>
<body>
    <div class="container">
        <a href="/" style="color:var(--primary); text-decoration:none; font-weight:700; display:inline-block; margin-bottom:20px;">← Ana Sayfaya Dön</a>
        <div class="card">
            <h2>Kredi Limiti Tahmini</h2>
            <p style="color:var(--text-dim); font-size:0.9rem;">Maaş ve mevcut borçlarınıza göre çekebileceğiniz maksimum tutarı öğrenin.</p>
            
            <div class="input-group">
                <label>AYLIK NET GELİR (₺)</label>
                <input type="number" id="income" placeholder="Örn: 45000">
            </div>
            <div class="input-group">
                <label>MEVCUT AYLIK KREDİ ÖDEMELERİ (₺)</label>
                <input type="number" id="existing" value="0">
            </div>

            <button onclick="estimateLimit()" style="background:var(--primary); color:#fff; border:none; padding:18px; border-radius:12px; width:100%; font-weight:800; cursor:pointer;">LİMİTİ HESAPLA</button>

            <div class="gauge-container" id="limitRes">
                <div class="limit-box">
                    <small style="color:rgba(255,255,255,0.8)">TAHMİNİ MAKSİMUM KREDİ LİMİTİNİZ</small>
                    <h1 id="maxLimit">0 ₺</h1>
                    <small id="monthlyCap" style="opacity:0.9"></small>
                </div>
                <p style="color:var(--text-dim); font-size:0.8rem; margin-top:20px;">* Bu hesaplama genel bankacılık rasyolarına (%50 borçlanma sınırı) göre yapılmıştır. Kredi notunuz sonucu değiştirebilir.</p>
            </div>
        </div>
    </div>

    <script>
        function estimateLimit() {
            const income = parseFloat(document.getElementById('income').value);
            const existing = parseFloat(document.getElementById('existing').value) || 0;

            if(!income) return alert("Lütfen gelirinizi girin.");

            // Bankalar genelde gelirin %50'sine kadar taksit izni verir
            const maxMonthlyPayment = (income * 0.5) - existing;
            
            if(maxMonthlyPayment <= 0) {
                document.getElementById('maxLimit').innerText = "Limit Yok";
                document.getElementById('monthlyCap').innerText = "Mevcut borçlarınız gelir sınırınızda.";
            } else {
                // Ortalama 36 ay vade ve 3.89 faiz ile çarpan (yaklaşık 18-20 katı)
                const totalLimit = maxMonthlyPayment * 20; 
                document.getElementById('maxLimit').innerText = Math.floor(totalLimit).toLocaleString() + " ₺";
                document.getElementById('monthlyCap').innerText = "Maksimum Aylık Taksit Gücü: " + Math.floor(maxMonthlyPayment).toLocaleString() + " ₺";
            }
            document.getElementById('limitRes').style.display = 'block';
        }
    </script>
</body>
</html>
