<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Limit Tahmini | Hesap360</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { background: #f8fafc; font-family: 'Plus Jakarta Sans', sans-serif; }
        .box { max-width: 500px; margin: 100px auto; background: #fff; padding: 40px; border-radius: 30px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
        input { width: 100%; padding: 15px; border: 1px solid #edf2f7; border-radius: 12px; margin: 20px 0; font-size: 1rem; }
        button { background: #0066ff; color: #fff; border: none; width: 100%; padding: 15px; border-radius: 12px; font-weight: 700; cursor: pointer; }
        #res { margin-top: 30px; display: none; }
    </style>
</head>
<body>
    <div class="box">
        <h2>Kredi Limitini Hesapla</h2>
        <p>Aylık gelirinizi girerek tahmini limiti görün.</p>
        <input type="number" id="inc" placeholder="Aylık Net Gelir (₺)">
        <button onclick="calc()">Hemen Hesapla</button>
        <div id="res"><h3>Tahmini Limit: <br><span id="val" style="color:#0066ff">0 TL</span></h3></div>
    </div>
    <script>
        function calc() {
            const v = document.getElementById('inc').value;
            if(v > 0) {
                document.getElementById('val').innerText = (v * 15).toLocaleString('tr-TR') + " TL";
                document.getElementById('res').style.display = 'block';
            }
        }
    </script>
</body>
</html>
